# Sequencing data / tool output — too large for git
fastqs/*
!fastqs/.gitkeep
*.sra
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# FastQC / QC reports
*_fastqc.html
*_fastqc.zip

# Reference genomes + aligner/samtools indexes — too large for git
refgenome/*
!refgenome/.gitkeep
*.fna
*.fna.gz
*.fa
*.fa.gz
*.fasta
*.amb
*.ann
*.bwt
*.pac
*.sa
*.fai

# Alignment output
*.sam
*.bam
*.bai
